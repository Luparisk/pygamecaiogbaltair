class PlayerBullet:
    """
    Projétil disparado pelo jogador.
    Suporta 4 estilos: normal, potion (gravidade forte), fireball, boomerang (retorna).
    """
    def __init__(self, x, y, vx, vy, color, damage=10, radius=6, kind="normal", sprite=None):
        self.fx=float(x); self.fy=float(y)      # Posição em float (precisão)
        self.vx=vx; self.vy=vy                   # Velocidade
        self.color=color; self.damage=damage
        self.radius=radius; self.kind=kind
        self.sprite = sprite                     # Imagem opcional
        self.life=180; self.age=0               # Vida em frames
        self.can_damage=True                     # Pode causar dano?
        self.returning=False                     # Boomerang voltando?
        self.return_started=False               # Flag: começou a retornar?
        size=max(2,radius*2)
        self.rect=pygame.Rect(int(x)-radius,int(y)-radius,size,size)

    def update(self):
        self.age+=1
        # Física específica por tipo
        if self.kind=="potion": self.vy+=0.12         # Cai com gravidade leve
        elif self.kind=="fireball": self.vy+=0.05     # Cai muito levemente
        elif self.kind=="boomerang":
            if self.age>65 and not self.return_started:
                # Inverte a direção após 65 frames
                self.returning=True; self.return_started=True
                self.vx=-self.vx*1.15; self.vy=-self.vy*0.9
            if self.returning: self.vx*=0.999; self.vy*=0.999  # Desacelera ao retornar
        self.fx+=self.vx; self.fy+=self.vy
        self.rect.center=(int(self.fx),int(self.fy))
        self.life-=1
        # Remove se sair da tela
        if self.rect.right<-60 or self.rect.left>BOSS_W+60 or self.rect.top>BOSS_H+60 or self.rect.bottom<-60:
            self.life=0

    def draw(self, surf):
        if self.sprite:
            img = self.sprite
            if self.vx < 0:
                img = pygame.transform.flip(img, True, False)  # Espelha se indo para esquerda
            center_blit(surf, img, self.rect.center)
            return
        if self.kind=="potion":
            pygame.draw.circle(surf,self.color,self.rect.center,self.radius)
            pygame.draw.circle(surf,WHITE,self.rect.center,max(2,self.radius//2)); return
        if self.kind=="fireball":
            pygame.draw.circle(surf,(255,80,20),self.rect.center,self.radius)
            pygame.draw.circle(surf,(255,200,60),self.rect.center,max(2,self.radius-3))
            pygame.draw.circle(surf,WHITE,self.rect.center,max(1,self.radius-6)); return
        # Normal e boomerang: elipse que pisca entre amarelo e laranja
        col=YELLOW if (self.age//2)%2==0 else ORANGE
        pygame.draw.ellipse(surf,col,self.rect)
        pygame.draw.ellipse(surf,WHITE,self.rect.inflate(-6,-2),2)


class Player:
    """
    Personagem controlado pelo jogador.
    Gerencia movimento, pulo, disparo (4 estilos), dano e animação de sprites.
    """
    W,H=36,52  # Tamanho da hitbox

    def __init__(self,character):
        # Copia atributos do dicionário do personagem
        self.character=character
        self.SPEED=character["speed"]; self.MAX_HP=character["max_hp"]
        self.body_color=character["body_color"]; self.head_color=character["head_color"]
        self.bullet_color=character["bullet_color"]; self.shot_style=character["shot_style"]
        self.shot_cd_max=character["shot_cd"]; self.shot_speed=character["shot_speed"]
        self.shot_damage=character["shot_damage"]; self.bullet_radius=character["bullet_radius"]
        # Atributos exclusivos do dragão (fireball)
        self.max_charge_frames=character.get("max_charge_frames",0)
        self.min_fire_speed=character.get("min_fire_speed",0)
        self.max_fire_speed=character.get("max_fire_speed",0)
        self.min_fire_damage=character.get("min_fire_damage",0)
        self.max_fire_damage=character.get("max_fire_damage",0)
        self.min_fire_radius=character.get("min_fire_radius",0)
        self.max_fire_radius=character.get("max_fire_radius",0)
        # Estado inicial
        self.rect=pygame.Rect(100,GROUND_Y-self.H,self.W,self.H)
        self.hp=self.MAX_HP; self.vel_y=0.0; self.on_ground=False
        self.invincible_frames=0; self.bullets=[]; self.shoot_cd=0
        self.facing=1    # 1 = direita, -1 = esquerda
        self.dead=False; self.anim_t=0.0
        self.is_charging=False; self.charge_frames=0
        self.asset_key = character["asset_key"]
        self.sprites = PLAYER_SPRITES.get(self.asset_key, {})
        self.move_dx = 0       # Direção horizontal atual (para animação)
        self.hurt_frames = 0   # Frames de animação de dano

    def get_weapon_damage(self):
        """Retorna o dano máximo da arma atual (para exibição no HUD)."""
        return self.max_fire_damage if self.shot_style=="fireball" else self.shot_damage

    def handle_physics(self, keys, platforms, ground_y):
        """
        Processa movimento horizontal, gravidade, pulo e colisões com
        o chão e plataformas.
        """
        dx = 0
        if keys[pygame.K_LEFT] or keys[pygame.K_a]:  dx -= self.SPEED
        if keys[pygame.K_RIGHT] or keys[pygame.K_d]: dx += self.SPEED
        self.move_dx = dx
        if dx != 0: self.facing = 1 if dx > 0 else -1

        self.rect.x += dx
        self.rect.x = clamp(self.rect.x, 0, BOSS_W - self.W)  # Limita aos limites da tela

        self.vel_y += 0.55   # Gravidade
        self.rect.y += int(self.vel_y)

        # Colisão com o chão
        self.on_ground = False
        if self.rect.bottom >= ground_y:
            self.rect.bottom = ground_y
            self.vel_y = 0
            self.on_ground = True

        # Colisão com plataformas (somente descendo, pela parte de cima)
        for plat in platforms:
            if self.vel_y >= 0 and self.rect.colliderect(plat) and self.rect.bottom - int(self.vel_y) <= plat.top + 6:
                self.rect.bottom = plat.top
                self.vel_y = 0
                self.on_ground = True

        # Pulo (somente quando no chão)
        if (keys[pygame.K_UP] or keys[pygame.K_w] or keys[pygame.K_SPACE]) and self.on_ground:
            self.vel_y = -15

    def _rotate(self,vx,vy,ang):
        """Rotaciona o vetor (vx,vy) por 'ang' radianos (para o tiro triplo)."""
        ca,sa=math.cos(ang),math.sin(ang)
        return vx*ca-vy*sa,vx*sa+vy*ca

    def _shoot_mouse(self,mx,my):
        """
        Cria projéteis em direção ao cursor do mouse.
        O comportamento varia conforme o shot_style do personagem.
        """
        ox,oy=self.rect.centerx,self.rect.centery
        dx=mx-ox; dy=my-oy; dist=math.hypot(dx,dy) or 1
        nx,ny=dx/dist,dy/dist   # Direção normalizada

        if self.shot_style=="potion":
            # Um projétil direto com física de queda
            self.bullets.append(PlayerBullet(ox,oy,nx*self.shot_speed,ny*self.shot_speed,
                                             self.bullet_color,damage=self.shot_damage,
                                             radius=self.bullet_radius,kind="potion"))
        elif self.shot_style=="triple":
            # Três projéteis em leque (-10°, 0°, +10°)
            for ang in(-0.18,0,0.18):
                rvx,rvy=self._rotate(nx*self.shot_speed,ny*self.shot_speed,ang)
                self.bullets.append(PlayerBullet(ox,oy,rvx,rvy,self.bullet_color,
                                                  damage=self.shot_damage,radius=self.bullet_radius,kind="normal"))
        elif self.shot_style=="fireball":
            # Dano/velocidade/tamanho escalam com o tempo de carga
            power=max(0.25,min(1.0,self.charge_frames/max(1,self.max_charge_frames)))
            speed=lerp(self.min_fire_speed,self.max_fire_speed,power)
            damage=int(lerp(self.min_fire_damage,self.max_fire_damage,power))
            radius=int(lerp(self.min_fire_radius,self.max_fire_radius,power))
            self.bullets.append(PlayerBullet(ox,oy,nx*speed,ny*speed,self.bullet_color,
                                              damage=damage,radius=radius,kind="fireball"))
        elif self.shot_style=="boomerang":
            self.bullets.append(PlayerBullet(ox,oy,nx*self.shot_speed,ny*self.shot_speed,
                                              self.bullet_color,damage=self.shot_damage,
                                              radius=self.bullet_radius,kind="boomerang"))

    def update_frank(self,events,ground_y=None,platforms=None):
        """
        Atualização principal do jogador a cada frame:
        física, disparo, projéteis, invencibilidade e animação.
        """
        if platforms is None: platforms=[]
        if ground_y is None: ground_y=GROUND_Y
        keys=pygame.key.get_pressed()
        self.handle_physics(keys,platforms,ground_y)
        self.shoot_cd=max(0,self.shoot_cd-1)

        mouse_down=pygame.mouse.get_pressed(num_buttons=3)[0]

        if self.shot_style=="fireball":
            # Inicia carregamento ao pressionar o botão
            for ev in events:
                if ev.type==pygame.MOUSEBUTTONDOWN and ev.button==1 and self.shoot_cd==0 and not self.is_charging:
                    self.is_charging=True; self.charge_frames=0
            if self.is_charging:
                if mouse_down:
                    self.charge_frames=min(self.max_charge_frames,self.charge_frames+1)  # Aumenta carga
                else:
                    # Dispara ao soltar o botão
                    mx,my=pygame.mouse.get_pos(); self._shoot_mouse(mx,my)
                    self.is_charging=False; self.shoot_cd=self.shot_cd_max
        else:
            # Outros estilos: dispara ao clicar diretamente
            for ev in events:
                if ev.type==pygame.MOUSEBUTTONDOWN and ev.button==1 and self.shoot_cd==0:
                    mx,my=pygame.mouse.get_pos(); self._shoot_mouse(mx,my)
                    self.shoot_cd=self.shot_cd_max

        # Atualiza e remove projéteis expirados
        for b in self.bullets[:]:
            b.update()
            if b.life<=0: self.bullets.remove(b)

        if self.invincible_frames>0: self.invincible_frames-=1
        if self.hurt_frames>0: self.hurt_frames-=1
        self.anim_t+=0.016  # Avança o tempo de animação

    def take_damage(self,dmg):
        """
        Aplica dano ao jogador.
        Ignora se DEBUG_INVENCIBLE ou durante frames de invencibilidade.
        """
        if DEBUG_INVENCIBLE: return
        if self.invincible_frames == 0:
            self.hp -= dmg
            self.invincible_frames = 45   # ~0.75s de invencibilidade pós-dano
            self.hurt_frames = 18         # Frames da animação de dano
            if self.hp <= 0: self.dead = True

    def draw(self,surf):
        """
        Seleciona a animação correta (idle/run/jump/hurt/shoot) e a desenha.
        Aplica tinte vermelho se tomando dano sem sprite de hurt.
        Desenha todos os projéteis ativos.
        """
        anim = None

        if self.hurt_frames > 0 and self.sprites.get("hurt"):
            anim = self.sprites.get("hurt")
        else:
            if self.on_ground:
                if self.move_dx != 0:
                    anim = self.sprites.get("run") or self.sprites.get("idle")
                else:
                    anim = self.sprites.get("idle")
            else:
                anim = self.sprites.get("jump") or self.sprites.get("idle")
            # Prioriza animação de disparo nos primeiros frames após atirar
            if self.shoot_cd > self.shot_cd_max - 4 and self.sprites.get("shoot"):
                anim = self.sprites.get("shoot")

        img = anim.get(self.anim_t) if anim else None

        if img:
            img = flip_if_needed(img, self.facing)  # Espelha se necessário
            if self.hurt_frames > 0 and not self.sprites.get("hurt"):
                # Aplica tinte vermelho semitransparente
                tint = pygame.Surface(img.get_size(), pygame.SRCALPHA)
                tint.fill((255, 80, 80, 110))
                img = img.copy()
                img.blit(tint, (0, 0), special_flags=pygame.BLEND_RGBA_ADD)
            center_blit(surf, img, self.rect.center)
        else:
            draw_player_sprite(surf, self)  # Fallback geométrico

        for b in self.bullets:
            b.draw(surf)

