#                                         FUNÇÕES DE DESENHO DO MENU


def draw_bg(surf=None):
    """Desenha o fundo do menu (imagem ou gradiente fallback)."""
    if surf is None:
        surf = tela
    surf.blit(img_fundo if img_fundo else _grad, (0, 0))

def draw_menu_base(surf, tempo):
    """
    Desenha a camada base do menu: fundo + partículas + logo flutuante.
    'tempo' é o tempo acumulado em segundos, usado para animações.
    """
    draw_bg(surf)

    # Atualiza e desenha cada partícula flutuante
    for p in particulas:
        p.update()
        p.draw(surf)

    # Efeito de flutuação senoidal do logo
    flutuacao = math.sin(tempo * 1.35) * 9
    logo_y = int(MENU_H * LOGO_POS_Y + flutuacao)

    if img_logo:
        lx = MENU_W // 2 - LOGO_W // 2
        # Sombra semitransparente do logo
        sh = pygame.Surface((LOGO_W, LOGO_H), pygame.SRCALPHA)
        sh.blit(img_logo, (0, 0))
        sh.set_alpha(65)
        surf.blit(sh, (lx + 6, logo_y + 10))  # Offset para simular sombra
        surf.blit(img_logo, (lx, logo_y))
    else:
        # Fallback: renderiza o título como texto
        ts = f_titulo.render(TITULO_FALLBACK, True, COR_TITULO_FB)
        ss = f_titulo.render(TITULO_FALLBACK, True, (0, 0, 0))  # Sombra preta
        surf.blit(ss, (MENU_W // 2 - ss.get_width() // 2 + 3, logo_y + 3))
