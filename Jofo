class NightmareProjectile:
    """
    Projétil do Lord of Nightmares. Três tipos:
    - "bolt": projétil direto
    - "wave": onda horizontal que atravessa a tela
    - "rain": projétil que cai com gravidade
    """
    def __init__(self, x, y, vx, vy, color, damage=18, kind="bolt", sprite=None):
        self.x=float(x); self.y=float(y)
        self.vx=vx; self.vy=vy; self.color=color
        self.damage=damage; self.kind=kind; self.life=240; self.age=0
        self.spin=random.uniform(0,math.pi*2); self.trail=[]
        # Hitbox varia por tipo
        if kind=="wave":   self.rect=pygame.Rect(int(x)-150,int(y)-18,300,36)
        elif kind=="rain": self.rect=pygame.Rect(int(x)-8,int(y)-8,16,22)
        else:              self.rect=pygame.Rect(int(x)-12,int(y)-12,24,24)
        self.sprite=sprite

    def update(self):
        self.age+=1; self.life-=1
        self.trail.append((self.rect.centerx,self.rect.centery))
        if len(self.trail)>8: self.trail.pop(0)
        if self.kind=="rain": self.vy+=0.18   # Gravidade na chuva
        self.x+=self.vx; self.y+=self.vy
        if self.kind=="wave":
            self.rect.x=int(self.x)-150; self.rect.y=int(self.y)-18
        else:
            self.rect.center=(int(self.x),int(self.y))

    def draw(self, surf):
        # Usa sprite se disponível para cada tipo
        if self.kind=="bolt" and self.sprite:
            center_blit(surf,self.sprite,self.rect.center); return
        if self.kind=="wave" and self.sprite:
            center_blit(surf,self.sprite,self.rect.center); return
        if self.kind=="rain" and self.sprite:
            center_blit(surf,self.sprite,self.rect.center); return
        pygame.draw.circle(surf,self.color,self.rect.center,10)
        pygame.draw.circle(surf,WHITE,self.rect.center,10,2)


class LordOfNightmares:
    """
    Boss Final: Lord of Nightmares.
    3 fases conforme HP diminui; escala de tamanho aumenta.
    Fase 1 (>66% HP): bolts e chuva.
    Fase 2 (33-66%): anel de projéteis + ondas.
    Fase 3 (<33%): anel maior + ondas duplas + chuva intensa.
    Fúria abaixo de 22%: tudo mais rápido e forte.
    """
    MAX_HP = 1800

    def __init__(self, visuals=None):
        self.v = visuals or {}
        self.hp = self.MAX_HP
        self.phase = 1; self.rage = False; self.phase_flash = 0
        self.t = 0                  # Tick para animações
        self.x = BOSS_W // 2; self.y = 170
        self.scale = 1.0; self.scale_target = 1.0  # Escala atual e alvo
        self.anchor_y = 170         # Posição Y base por fase
        self.attack_cd = 0; self.special_cd = 0
        self.projectiles = []
        self.rect = pygame.Rect(0, 0, 180, 260)
        self._sync_rect()

    def _sync_rect(self):
        """Atualiza o retângulo de colisão conforme a escala atual."""
        w=int(210*self.scale); h=int(280*self.scale)
        self.rect=pygame.Rect(int(self.x-w//2),int(self.y-h//2),w,h)

    def _shoot_bolt(self,player,spread=0.0,speed=8.0,color=PURPLE,damage=16):
        dx=player.rect.centerx-self.rect.centerx; dy=player.rect.centery-self.rect.centery
        ang=math.atan2(dy,dx)+spread
        self.projectiles.append(NightmareProjectile(self.rect.centerx,self.rect.centery,
                                                     math.cos(ang)*speed,math.sin(ang)*speed,
                                                     color,damage,"bolt"))

    def _shoot_ring(self,count,speed,color,damage=14):
        """Dispara projéteis em anel (360°) com rotação baseada no tempo."""
        for i in range(count):
            ang=(math.tau/count)*i+self.t*0.015
            self.projectiles.append(NightmareProjectile(self.rect.centerx,self.rect.centery,
                                                         math.cos(ang)*speed,math.sin(ang)*speed,
                                                         color,damage,"bolt"))

    def _spawn_rain(self,player,count=4):
        """Chuva de projéteis que cai do topo em posições aleatórias perto do jogador."""
        for _ in range(count):
            rx=clamp(player.rect.centerx+random.randint(-260,260),40,BOSS_W-40)
            self.projectiles.append(NightmareProjectile(rx,-30,
                                                         random.uniform(-0.3,0.3),
                                                         random.uniform(5.5,7.5),
                                                         CYAN,15 if not self.rage else 20,"rain"))

    def _spawn_wave(self,player,direction=1):
        """Onda horizontal que atravessa a tela da esquerda para direita ou vice-versa."""
        y=clamp(player.rect.centery+random.randint(-80,60),120,BOSS_H-150)
        x=-120 if direction>0 else BOSS_W+120
        vx=11 if direction>0 else -11
        self.projectiles.append(NightmareProjectile(x,y,vx,0,ORANGE,
                                                     22 if not self.rage else 28,"wave"))

    def _update_phase(self):
        """Determina a fase atual pelo ratio de HP e atualiza escala/âncora."""
        ratio=self.hp/self.MAX_HP; old_phase=self.phase
        if ratio>0.66:   self.phase=1; self.scale_target=1.00; self.anchor_y=170
        elif ratio>0.33: self.phase=2; self.scale_target=1.35; self.anchor_y=255
        else:            self.phase=3; self.scale_target=1.85; self.anchor_y=335
        self.rage=ratio<=0.22
        if self.phase!=old_phase:
            # Transição de fase: efeito visual e cooldowns resetados
            self.phase_flash=24; self.projectiles.clear()
            self.attack_cd=18; self.special_cd=36
            add_screen_shake(10 if self.phase==3 else 6,5 if self.phase==3 else 3)

    def update(self,player):
        self.t+=1; self._update_phase()

        # Movimento senoidal com amplitude e velocidade por fase
        move_amp=230 if self.phase==1 else 320 if self.phase==2 else 380
        move_speed=0.020 if self.phase==1 else 0.028 if self.phase==2 else 0.036
        y_amp=18 if self.phase==1 else 28 if self.phase==2 else 14

        target_x=BOSS_W//2+math.sin(self.t*move_speed)*move_amp
        target_y=self.anchor_y+math.sin(self.t*(move_speed*1.7))*y_amp
        if self.phase==3: target_y+=math.sin(self.t*0.11)*10

        self.x=lerp(self.x,target_x,0.05 if self.phase<3 else 0.07)
        self.y=lerp(self.y,target_y,0.04 if self.phase<3 else 0.06)
        self.scale=lerp(self.scale,self.scale_target,0.05)
        self._sync_rect()

        self.attack_cd-=1; self.special_cd-=1

        # Padrões de ataque por fase
        if self.phase==1:
            if self.attack_cd<=0:
                self.attack_cd=42 if not self.rage else 28
                # 3 bolts com leve espalhamento
                for spread in (0.0,-0.12,0.12):
                    self._shoot_bolt(player,spread,8.0 if not self.rage else 10.0,PURPLE,16 if not self.rage else 20)
            if self.special_cd<=0:
                self.special_cd=110 if not self.rage else 75
                self._spawn_rain(player,3 if not self.rage else 5)

        elif self.phase==2:
            if self.attack_cd<=0:
                self.attack_cd=30 if not self.rage else 22
                self._shoot_ring(8,6.8 if not self.rage else 8.2,RED,16 if not self.rage else 20)
                self._shoot_bolt(player,0.0,9.0 if not self.rage else 11.0,RED,18 if not self.rage else 22)
            if self.special_cd<=0:
                self.special_cd=85 if not self.rage else 60
                self._spawn_wave(player,1 if(self.t//60)%2==0 else -1)
                if self.rage: self._spawn_wave(player,-1 if(self.t//60)%2==0 else 1)

        else:  # Fase 3
            if self.attack_cd<=0:
                self.attack_cd=20 if not self.rage else 14
                self._shoot_ring(12,7.5 if not self.rage else 9.2,ORANGE,20 if not self.rage else 24)
            if self.special_cd<=0:
                self.special_cd=55 if not self.rage else 38
                self._spawn_wave(player,1); self._spawn_wave(player,-1)
                self._spawn_rain(player,5 if not self.rage else 8)

        # Limpa projéteis fora da tela
        for p in self.projectiles[:]:
            p.update()
            if p.life<=0 or p.rect.right<-80 or p.rect.left>BOSS_W+80 or \
               p.rect.bottom<-80 or p.rect.top>BOSS_H+80:
                self.projectiles.remove(p)

    def draw_bg(self, surf):
        """Fundo muda conforme a fase: estrelas roxas → tiras vermelhas → caos total."""
        bg=self.v.get("bg1") if self.phase==1 else self.v.get("bg2") if self.phase==2 else self.v.get("bg3")
        if bg: surf.blit(bg,(0,0)); return
        if self.phase==1:
            surf.fill((8,0,18))
            for i in range(90):
                x=(i*153+self.t*2)%BOSS_W; y=(i*67)%(BOSS_H//2)
                pygame.draw.circle(surf,(70,20,110),(int(x),y),1)
            overlay=pygame.Surface((BOSS_W,BOSS_H),pygame.SRCALPHA); overlay.fill((40,0,70,22)); surf.blit(overlay,(0,0))
        elif self.phase==2:
            surf.fill((14,0,8))
            for x in range(0,BOSS_W,90):
                pygame.draw.rect(surf,(50,0,30),(x,0,42,BOSS_W),0)
                pygame.draw.rect(surf,(90,0,50),(x+42,0,20,BOSS_H),0)
            fog=pygame.Surface((BOSS_W,BOSS_H),pygame.SRCALPHA); fog.fill((120,0,0,18 if not self.rage else 30)); surf.blit(fog,(0,0))
        else:
            surf.fill((3,0,10))
            for i in range(160):
                px=(i*79+self.t*3)%BOSS_W; py=(i*41+(i%7)*23)%BOSS_H; c=40+(i%5)*12
                pygame.draw.circle(surf,(c,0,c+20),(int(px),int(py)),1)

    def draw(self, surf):
        self.draw_bg(surf)
        if self.phase_flash>0:
            flash=pygame.Surface((BOSS_W,BOSS_H),pygame.SRCALPHA); flash.fill((255,0,120,35)); surf.blit(flash,(0,0))
            self.phase_flash-=1
        img=self.v.get("boss")
        if img:
            center_blit(surf,img.get(self.t/10.0),(int(self.x),int(self.y)))
        else:
            # Fallback: figura encapuzada escalável com chifres na fase 3
            w=int(220*self.scale); h=int(320*self.scale)
            body=pygame.Rect(0,0,w,h); body.center=(int(self.x),int(self.y))
            # Aura ao redor do corpo
            aura=pygame.Surface((w+180,h+220),pygame.SRCALPHA)
            aura_col=(130,0,190,70) if self.phase<3 else (255,40,20,80)
            pygame.draw.ellipse(aura,aura_col,(30,40,aura.get_width()-60,aura.get_height()-80))
            surf.blit(aura,(body.centerx-aura.get_width()//2,body.centery-aura.get_height()//2))
            cloak_col=(20,16,30) if not self.rage else (40,10,16)
            cloak_outline=(80,0,120) if self.phase<3 else (255,40,60)
            hood_col=(30,24,42) if not self.rage else (60,14,24)
            pygame.draw.ellipse(surf,cloak_col,body.inflate(0,-20))
            pygame.draw.ellipse(surf,cloak_outline,body.inflate(0,-20),4)
            hood=pygame.Rect(body.centerx-int(72*self.scale),body.top+int(12*self.scale),
                             int(144*self.scale),int(122*self.scale))
            pygame.draw.ellipse(surf,hood_col,hood)
            pygame.draw.ellipse(surf,cloak_outline,hood,3)
            eye_y=hood.centery; eye_dx=int(20*self.scale)
            eye_color=RED if self.rage else PURPLE
            pygame.draw.circle(surf,eye_color,(hood.centerx-eye_dx,eye_y),max(3,int(7*self.scale)))
            pygame.draw.circle(surf,eye_color,(hood.centerx+eye_dx,eye_y),max(3,int(7*self.scale)))
            arm_w=max(6,int(14*self.scale))
            for side in(-1,1):
                ax=body.centerx+side*int(65*self.scale); ay=body.top+int(120*self.scale)
                bx=ax+side*int(95*self.scale); by=ay+int(45*math.sin(self.t*0.05+side))
                pygame.draw.line(surf,(50,40,70),(ax,ay),(bx,by),arm_w)
            if self.phase>=2:
                sigil_r=int(70*self.scale)
                pygame.draw.circle(surf,(100,0,140),(body.centerx,body.bottom-int(40*self.scale)),sigil_r,3)
            if self.phase==3:
                for side in(-1,1):
                    horn=[(hood.centerx+side*int(24*self.scale),hood.top+int(12*self.scale)),
                           (hood.centerx+side*int(70*self.scale),hood.top-int(34*self.scale)),
                           (hood.centerx+side*int(48*self.scale),hood.top+int(18*self.scale))]
                    pygame.draw.polygon(surf,(140,0,180),horn)
        for p in self.projectiles: p.draw(surf)
        # Barra de HP global do boss
        bw=520; bx=BOSS_W//2-bw//2
        pygame.draw.rect(surf,GRAY,(bx,20,bw,22),border_radius=8)
        hp_col=PURPLE if self.phase<3 else (255,80,40)
        pygame.draw.rect(surf,hp_col,(bx,20,int(bw*max(0,self.hp)/self.MAX_HP),22),border_radius=8)
        pygame.draw.rect(surf,WHITE,(bx,20,bw,22),2,border_radius=8)
        draw_text(surf,"LORD OF NIGHTMARES",font_sm,WHITE,BOSS_W//2,31)
        phase_name="Forma Sombria" if self.phase==1 else "Palco do Caos" if self.phase==2 else "Forma Verdadeira"
        draw_text(surf,f"Fase {self.phase} - {phase_name}",font_tiny,CYAN if self.phase<3 else ORANGE,BOSS_W//2,58)

