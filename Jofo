class Particula:
    """
    Pequenas partículas laranja que sobem pela tela do menu,
    criando um efeito de brasas ou chamas.
    """
    def __init__(self, rand=True):
        self.reset(rand)

    def reset(self, rand=False):
        """Reposiciona a partícula. Se rand=True, começa em posição aleatória na tela."""
        self.x     = random.uniform(0, MENU_W)
        self.y     = random.uniform(0, MENU_H) if rand else MENU_H + 4  # Começa abaixo da tela
        self.r     = random.uniform(1.0, 3.0)    # Raio
        self.vel   = random.uniform(0.3, 1.0)    # Velocidade de subida
        self.alpha = random.randint(50, 170)     # Transparência

    def update(self):
        """Sobe a partícula; reinicia quando sai pelo topo da tela."""
        self.y -= self.vel
        if self.y < -5: self.reset()

    def draw(self, surf):
        """Desenha a partícula como um círculo semitransparente."""
        s = pygame.Surface((int(self.r*2+2), int(self.r*2+2)), pygame.SRCALPHA)
        pygame.draw.circle(s, (*COR_PARTICULA, self.alpha),
                           (int(self.r)+1, int(self.r)+1), int(self.r))
        surf.blit(s, (int(self.x-self.r), int(self.y-self.r)))

# Cria o pool de 90 partículas já distribuídas pela tela
particulas = [Particula(rand=True) for _ in range(90)]


