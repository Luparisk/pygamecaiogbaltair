class DrFrankenstein:
    """
    Fase 1 do Boss 2: Dr. Frankenstein.
    Teleporta entre 3 colunas Tesla e atira projéteis.
    Em fúria: teleporta mais rápido e faz rajadas.
    """
    W, H = 60, 100
    MAX_HP = 500
    TELEPORT_INTERVAL = 170       # Frames entre teleportes normais
    RAGE_TELEPORT_INTERVAL = 120  # Frames entre teleportes em fúria
    SHOOT_INTERVAL = 54           # Frames entre tiros normais
    RAGE_SHOOT_INTERVAL = 34      # Frames entre tiros em fúria
    BURST_INTERVAL = 110          # Frames entre rajadas (só em fúria)
    RAGE_THRESHOLD = 220          # HP que ativa a fúria

    def __init__(self, visuals=None):
        self.v = visuals or {}
        self.pillar_idx = 1        # Começa na coluna central
        self.rect = self._pillar_rect(1)
        self.hp = self.MAX_HP
        self.teleport_cd = self.TELEPORT_INTERVAL
        self.shoot_cd = self.SHOOT_INTERVAL
        self.burst_cd = self.BURST_INTERVAL
        self.bullets = []; self.particles = []
        self.teleport_flash = 0    # Frames do efeito de piscar ao teleportar
        self.visible = True        # Visível durante o teleporte?
        self.rage = False
        self.bg_anim = 0           # Contador para animações de fundo

    def draw_bg(self, surf, tick):
        bg = self.v.get("bg")
        if bg: surf.blit(bg, (0, 0))
        else: draw_lab_bg(surf, tick, rage=self.rage)

    def _pillar_rect(self, idx):
        """Retorna o Rect do doutor na coluna de índice idx (0, 1 ou 2)."""
        x = TESLA_XS[idx] - self.W // 2
        y = BOSS_H - 80 - self.H - 210   # Acima da coluna
        return pygame.Rect(x, y, self.W, self.H)

    def _spawn_particles(self, rect, count=40):
        """Gera partículas de teleporte ao redor do retângulo dado."""
        cx, cy = rect.centerx, rect.centery
        for _ in range(count):
            self.particles.append(TeleportParticle(
                cx + random.randint(-self.W//2, self.W//2),
                cy + random.randint(-self.H//2, self.H//2)
            ))

    def _shoot_one(self, player, speed=None, damage=None, spread=0.0):
        """Atira um projétil em direção ao jogador com desvio angular opcional."""
        dx = player.rect.centerx - self.rect.centerx
        dy = player.rect.centery - self.rect.centery
        ang = math.atan2(dy, dx) + spread
        spd = speed if speed is not None else (7 if self.rage else 5.5)
        dmg = damage if damage is not None else (13 if self.rage else 10)
        self.bullets.append(DrBullet(self.rect.centerx, self.rect.centery,
                                      math.cos(ang)*spd, math.sin(ang)*spd,
                                      damage=dmg, sprite=self.v.get("bullet")))

    def _shoot_burst(self, player):
        """Rajada de 3 projéteis em leque (só em fúria)."""
        for spread in (-0.22, 0, 0.22):
            self._shoot_one(player, speed=6.7 if self.rage else 6.0,
                            damage=12 if self.rage else 9, spread=spread)

    def update(self, player):
        self.bg_anim += 1
        self.rage = self.hp <= self.RAGE_THRESHOLD

        t_int = self.RAGE_TELEPORT_INTERVAL if self.rage else self.TELEPORT_INTERVAL
        s_int = self.RAGE_SHOOT_INTERVAL if self.rage else self.SHOOT_INTERVAL
        b_int = max(42, self.BURST_INTERVAL - 25) if self.rage else self.BURST_INTERVAL

        self.teleport_cd -= 1
        if self.teleport_cd <= 0:
            # Teleporta para uma coluna diferente da atual
            self._spawn_particles(self.rect, count=60 if self.rage else 50)
            choices = [i for i in range(3) if i != self.pillar_idx]
            self.pillar_idx = random.choice(choices)
            self.rect = self._pillar_rect(self.pillar_idx)
            self.teleport_cd = t_int; self.teleport_flash = 25
            self.shoot_cd = 18 if self.rage else 25
            self.burst_cd = b_int
            self._spawn_particles(self.rect, count=60 if self.rage else 50)
            add_screen_shake(5 if self.rage else 3, 4 if self.rage else 2)

        # Efeito de piscar durante o teleporte
        if self.teleport_flash > 0:
            self.teleport_flash -= 1
            self.visible = (self.teleport_flash // 4) % 2 == 0
        else:
            self.visible = True

        self.shoot_cd -= 1
        if self.shoot_cd <= 0:
            self.shoot_cd = s_int; self._shoot_one(player)

        if self.rage:
            self.burst_cd -= 1
            if self.burst_cd <= 0:
                self._shoot_burst(player); self.burst_cd = b_int

        screen_rect = pygame.Rect(0, 0, BOSS_W, BOSS_H)
        for b in self.bullets[:]:
            b.update()
            if not screen_rect.colliderect(b.rect): self.bullets.remove(b)

        for p in self.particles[:]:
            p.update()
            if p.life <= 0: self.particles.remove(p)

    def take_damage(self, dmg):
        self.hp -= dmg

    def _draw_hp(self, surf):
        """Barra de HP do doutor no topo da tela."""
        bw=320; bx=BOSS_W//2-bw//2; by=12
        pygame.draw.rect(surf,GRAY,(bx,by,bw,22),border_radius=5)
        ratio=max(0,self.hp)/self.MAX_HP
        col=(255,90,50) if self.rage else PURPLE
        pygame.draw.rect(surf,col,(bx,by,int(bw*ratio),22),border_radius=5)
        txt=f"Dr. Frankenstein  {self.hp}/{self.MAX_HP}"
        if self.rage: txt+="  [FÚRIA]"
        draw_text(surf,txt,font_sm,WHITE,BOSS_W//2,by+11)

    def draw(self, surf):
        """Desenha fundo, colunas, partículas, sprite do doutor e barra de HP."""
        self.draw_bg(surf, self.bg_anim)
        for px, variant in zip(TESLA_XS, ["left", "center", "right"]):
            draw_detailed_pillar(surf, px, BOSS_H-80, 235, pulse=self.bg_anim, active=True, variant=variant)
        for p in self.particles: p.draw(surf)
        if self.visible:
            img = self.v.get("doctor")
            if img and img.frames:
                frame = img.get(self.bg_anim / 10.0)
                if frame: center_blit(surf, frame, self.rect.center)
        self._draw_hp(surf)


# Constantes das mãos do monstro 
HAND_Y_REST  = BOSS_H-80-140   # Y de repouso das mãos
HAND_Y_SMASH = BOSS_H-80-30   # Y no momento do ataque (quase no chão)


class MonsterHand:
    """
    Mão do monstro (fase 2 do boss 2).
    Estados: rest → windup → smash → recover → rest.
    Causa dano ao jogador durante o "smash".
    """
    W, H = 110, 90

    def __init__(self, side, sprite=None):
        self.side = side   # "left" ou "right"
        self.sprite = sprite
        self.x = 120 if side == "left" else BOSS_W - 120 - self.W
        self.y = float(HAND_Y_REST)
        self.state = "rest"
        self.timer = 0

    @property
    def rect(self):
        return pygame.Rect(int(self.x), int(self.y), self.W, self.H)

    def start_attack(self, player_x):
        """Inicia o ataque alinhando a mão horizontalmente com o jogador."""
        if self.state == "rest":
            self.state = "windup"; self.timer = 45
            self.x = max(0, min(BOSS_W - self.W, player_x - self.W // 2))

    def update(self, rage=False):
        if self.state == "windup":
            # Sobe lentamente antes de atacar
            self.y = lerp(self.y, HAND_Y_REST - (180 if rage else 165), 0.22 if rage else 0.18)
            self.timer -= 1
            if self.timer <= 0: self.state = "smash"
        elif self.state == "smash":
            # Desce rapidamente para atacar
            self.y = lerp(self.y, HAND_Y_SMASH, 0.48 if rage else 0.40)
            if self.y >= HAND_Y_SMASH - 4:
                self.state = "recover"; self.timer = 28 if rage else 35
        elif self.state == "recover":
            # Retorna ao repouso
            self.y = lerp(self.y, HAND_Y_REST, 0.16 if rage else 0.12)
            self.timer -= 1
            if self.timer <= 0: self.state = "rest"

    def is_smashing(self):
        """Retorna True se a mão está no ponto de impacto."""
        return self.state == "smash" and self.y >= HAND_Y_SMASH - 10

    def draw(self, surf):
        if self.sprite:
            img = self.sprite
            if self.side == "right":
                img = pygame.transform.flip(img, True, False)  # Espelha a mão direita
            center_blit(surf, img, self.rect.center); return
        # Fallback: mão verde com 4 dedos
        r = self.rect
        pygame.draw.rect(surf, (30,110,30), r, border_radius=10)
        fw = (r.w - 10) // 4
        for i in range(4):
            fx = r.x + 5 + i * (fw + 2)
            fh = [28, 32, 30, 26][i]
            pygame.draw.rect(surf, (30,110,30), pygame.Rect(fx, r.y-fh, fw, fh), border_radius=6)
        pygame.draw.rect(surf, (10,60,10), r, 3, border_radius=10)


class MonsterPhase:
    """
    Fase 2 do Boss 2: O Monstro de Frankenstein.
    Alterna entre fases de ataque com mãos (smash) e raios (lightning).
    """
    MAX_HP = 850
    SMASH_DURATION = 300       # Frames da fase de ataque com mãos
    PAUSE_DURATION = 35        # Frames de pausa entre fases
    HAND_ATTACK_INTERVAL = 42  # Frames entre ataques das mãos
    RAGE_THRESHOLD = 320       # HP que ativa fúria
    STOMP_INTERVAL = 230       # Frames entre pisões

    def __init__(self, visuals=None):
        self.v = visuals or {}
        self.hp = self.MAX_HP
        self.hands = [MonsterHand("left", self.v.get("hand_left")),
                      MonsterHand("right", self.v.get("hand_right"))]
        self.bg_anim = 0
        self.state = "smash"        # Estado inicial
        self.state_cd = self.SMASH_DURATION
        self.attack_cd = self.HAND_ATTACK_INTERVAL
        self.next_hand = 0          # Qual mão ataca a seguir (alternado)
        self.safe_zone = None       # Zona segura durante os raios
        self.stomp = None           # Ataque de pisão ativo
        self.stomp_cd = self.STOMP_INTERVAL
        self.rage = False

    def take_damage(self, dmg):
        self.hp -= dmg

    def update(self, player):
        self.bg_anim += 1
        self.rage = self.hp <= self.RAGE_THRESHOLD
        self.state_cd -= 1

        # Atualiza pisão se ativo
        if self.stomp: self.stomp.update()
        if self.stomp and self.stomp.done:
            self.stomp = None
            self.stomp_cd = 165 if self.rage else self.STOMP_INTERVAL

        # Máquina de estados das fases
        if self.state_cd <= 0 and self.stomp is None:
            if self.state == "smash":
                self.state = "pause_after_smash"; self.state_cd = self.PAUSE_DURATION
            elif self.state == "pause_after_smash":
                self.state = "lightning"; self.state_cd = 9999
                self.safe_zone = LightningSafeZone(rage=self.rage)
            elif self.state == "lightning":
                self.state = "pause_after_lightning"; self.state_cd = self.PAUSE_DURATION
                self.safe_zone = None
            elif self.state == "pause_after_lightning":
                self.state = "smash"; self.state_cd = self.SMASH_DURATION

        if self.state == "smash":
            hand_interval = 28 if self.rage else self.HAND_ATTACK_INTERVAL
            self.attack_cd -= 1
            if self.attack_cd <= 0:
                # Alterna entre mão esquerda e direita
                self.hands[self.next_hand].start_attack(player.rect.centerx)
                self.next_hand = 1 - self.next_hand
                self.attack_cd = hand_interval
            self.stomp_cd -= 1
            if self.stomp_cd <= 0 and self.stomp is None:
                self.stomp = StompAttack(player.rect.centerx, rage=self.rage)
                self.stomp_cd = 9999
                add_screen_shake(10 if self.rage else 8, 6 if self.rage else 4)

        elif self.state == "lightning" and self.safe_zone:
            self.safe_zone.update()
            if self.safe_zone.done: self.state_cd = 0

        for hand in self.hands: hand.update(rage=self.rage)

    def check_hits(self, player):
        """Verifica colisões das mãos, zona de raio e pisão com o jogador."""
        for hand in self.hands:
            if hand.is_smashing() and player.rect.colliderect(hand.rect):
                player.take_damage(32 if self.rage else 28)
        if self.safe_zone and self.safe_zone.player_in_danger(player.rect):
            player.take_damage(20 if self.rage else 16)
        if self.stomp and self.stomp.can_hit_player(player):
            player.take_damage(30 if self.rage else 24)
            self.stomp.mark_hit()

    def _draw_hp(self, surf):
        bw=380; bx=BOSS_W//2-bw//2; by=12
        pygame.draw.rect(surf,GRAY,(bx,by,bw,22),border_radius=5)
        col=(255,90,50) if self.rage else GREEN
        pygame.draw.rect(surf,col,(bx,by,int(bw*max(0,self.hp)/self.MAX_HP),22),border_radius=5)
        txt=f"MONSTRO  {self.hp}/{self.MAX_HP}"
        if self.rage: txt+="  [FÚRIA]"
        draw_text(surf,txt,font_sm,WHITE,BOSS_W//2,by+11)

    def draw(self, surf):
        bg = self.v.get("bg")
        if bg: surf.blit(bg, (0, 0))
        else: self.draw_bg(surf, self.bg_anim)
        monster_anim = self.v.get("monster")
        if monster_anim and monster_anim.frames:
            img = monster_anim.get(self.bg_anim / 10.0)
            if img: center_blit(surf, img, (BOSS_W//2, BOSS_H//2-20))
        if self.safe_zone: self.safe_zone.draw(surf)
        if self.stomp: self.stomp.draw(surf)
        for hand in self.hands: hand.draw(surf)
        self._draw_hp(surf)

    def draw_bg(self, surf, tick):
        surf.fill((12, 14, 24))


class StompAttack:
    """
    Ataque de pisão: aviso visual → onda de choque se expande pelo chão.
    Jogadores no chão dentro do raio levam dano.
    """
    def __init__(self,x,rage=False):
        self.x=x; self.rage=rage
        self.state="warn"                          # Fase de aviso
        self.timer=24 if rage else 34              # Duração do aviso
        self.strike_frames=24 if rage else 18      # Duração da onda
        self.recover_frames=16
        self.radius=0
        self.max_radius=760 if rage else 620       # Raio máximo da onda
        self.hit_done=False; self.done=False

    def update(self):
        self.timer-=1
        if self.state=="warn":
            self.radius=80
            if self.timer<=0:
                self.state="strike"; self.timer=self.strike_frames
                add_screen_shake(10 if self.rage else 7, 7 if self.rage else 5)
        elif self.state=="strike":
            self.radius=min(self.max_radius,self.radius+(70 if self.rage else 52))
            if self.timer<=0: self.state="recover"; self.timer=self.recover_frames
        elif self.state=="recover":
            if self.timer<=0: self.done=True

    def can_hit_player(self,player):
        if self.state!="strike" or self.hit_done: return False
        return player.rect.bottom>=BOSS_H-155 and abs(player.rect.centerx-self.x)<=self.radius

    def mark_hit(self): self.hit_done=True

    def draw(self,surf):
        ground_y=BOSS_H-80
        if self.state=="warn":
            pygame.draw.circle(surf,(255,180,60),(self.x,ground_y+8),30)
            pygame.draw.circle(surf,(255,255,180),(self.x,ground_y+8),14)
            if(self.timer//6)%2==0: draw_text(surf,"PISAO!",font_lg,ORANGE,self.x,ground_y-70)
        elif self.state in("strike","recover"):
            # Onda elíptica que se expande pelo chão
            alpha=200 if self.state=="strike" else 90
            ring=pygame.Surface((self.radius*2+12,120),pygame.SRCALPHA)
            pygame.draw.ellipse(ring,(255,200,80,alpha),pygame.Rect(6,34,self.radius*2,38),6)
            surf.blit(ring,(self.x-self.radius-6,ground_y-26))


class LightningSafeZone:
    """
    Ataque de raios do monstro: toda a tela é atingida exceto uma zona segura aleatória.
    Fases: warn (aviso verde) → strike (raios caem) → fade.
    """
    def __init__(self,rage=False):
        self.rage=rage
        self.SAFE_W=95 if rage else 120           # Largura da zona segura
        self.WARN_FRAMES=60 if rage else 75       # Duração do aviso
        self.STRIKE_FRAMES=92 if rage else 80     # Duração dos raios
        self.FADE_FRAMES=18
        self.reset()

    def reset(self):
        self.safe_x=random.randint(60,BOSS_W-self.SAFE_W-60)  # Posição aleatória
        self.state="warn"; self.timer=self.WARN_FRAMES
        self.bolts=[]; self.done=False; self._bolt_cd=0

    @property
    def safe_rect(self): return pygame.Rect(self.safe_x,0,self.SAFE_W,BOSS_H)

    def update(self):
        self.timer-=1
        if self.state=="warn":
            if self.timer<=0: self.state="strike"; self.timer=self.STRIKE_FRAMES; self._spawn_bolts()
        elif self.state=="strike":
            self._bolt_cd-=1
            if self._bolt_cd<=0: self._spawn_bolts(); self._bolt_cd=5 if self.rage else 7
            if self.timer<=0: self.state="fade"; self.timer=self.FADE_FRAMES
        elif self.state=="fade":
            if self.timer<=0: self.done=True
        for b in self.bolts[:]:
            b["life"]-=1
            if b["life"]<=0: self.bolts.remove(b)

    def _spawn_bolts(self):
        """Gera raios ziguezagueantes nas áreas fora da zona segura."""
        if self.safe_x>40:
            for _ in range(random.randint(4 if self.rage else 3, 6 if self.rage else 5)):
                self.bolts.append(self._make_bolt(random.randint(10,self.safe_x-10)))
        right_start=self.safe_x+self.SAFE_W
        if right_start<BOSS_W-40:
            for _ in range(random.randint(4 if self.rage else 3, 6 if self.rage else 5)):
                self.bolts.append(self._make_bolt(random.randint(right_start+10,BOSS_W-10)))

    def _make_bolt(self,x):
        """Cria um raio ziguezagueante de cima a baixo a partir de X."""
        segs=[]; cy_b=0; cx_b=x
        while cy_b<BOSS_H:
            ny=cy_b+random.randint(18,45); nx=cx_b+random.randint(-22,22)
            segs.append(((cx_b,cy_b),(nx,ny))); cx_b,cy_b=nx,ny
        return{"segs":segs,"life":random.randint(8,18)}

    def player_in_danger(self,player_rect):
        return self.state=="strike" and not self.safe_rect.colliderect(player_rect)

    def draw(self,surf):
        if self.state=="warn":
            progress=1-self.timer/self.WARN_FRAMES
            alpha=int(80+80*abs(math.sin(progress*math.pi*6)))
            ov=pygame.Surface((BOSS_W,BOSS_H),pygame.SRCALPHA); ov.fill((200,50,0,alpha)); surf.blit(ov,(0,0))
            sz=pygame.Surface((self.SAFE_W,BOSS_H),pygame.SRCALPHA); sz.fill((0,220,80,60)); surf.blit(sz,(self.safe_x,0))
            pygame.draw.rect(surf,(0,255,100),pygame.Rect(self.safe_x,0,self.SAFE_W,BOSS_H),3)
            if(self.timer//10)%2==0: draw_text(surf,"AVISO DE RAIO",font_lg,YELLOW,BOSS_W//2,BOSS_H//2-60)
        elif self.state=="strike":
            for b in self.bolts:
                for(ax,ay),(bx2,by2) in b["segs"]:
                    pygame.draw.line(surf,BOLT_C,(ax,ay),(bx2,by2),3)
                    pygame.draw.line(surf,WHITE,(ax,ay),(bx2,by2),1)
            sz=pygame.Surface((self.SAFE_W,BOSS_H),pygame.SRCALPHA); sz.fill((0,220,80,35)); surf.blit(sz,(self.safe_x,0))
            pygame.draw.rect(surf,(0,255,100),pygame.Rect(self.safe_x,0,self.SAFE_W,BOSS_H),3)



