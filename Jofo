def character_select():
    """
    Loop da tela de seleção de personagem.
    Navegação com LEFT/RIGHT ou clique.
    Retorna o dicionário do personagem escolhido.
    """
    selected = 0         # Índice do personagem selecionado
    clock_sel = pygame.time.Clock()
    t = 0.0              # Tempo para animações

    while True:
        dt = clock_sel.tick(FPS) / 1000.0
        t += dt
        events = pygame.event.get()
        start_game = False

        for ev in events:
            if ev.type == pygame.QUIT:
                pygame.quit(); sys.exit()
            if ev.type == pygame.KEYDOWN:
                if ev.key == pygame.K_LEFT:
                    selected = (selected - 1) % len(CHARACTERS)   # Navega para esquerda (circular)
                elif ev.key == pygame.K_RIGHT:
                    selected = (selected + 1) % len(CHARACTERS)   # Navega para direita (circular)
                elif ev.key in (pygame.K_RETURN, pygame.K_SPACE):
                    start_game = True
                elif ev.key == pygame.K_ESCAPE:
                    pygame.quit(); sys.exit()
            if botao.clicado(ev):
                start_game = True

        draw_menu_base(tela, t)  # Reutiliza o fundo animado do menu

        # Overlay semitransparente para destacar o conteúdo
        overlay = pygame.Surface((MENU_W, MENU_H), pygame.SRCALPHA)
        overlay.fill((0, 0, 0, 35))
        tela.blit(overlay, (0, 0))

        draw_text(tela, "ESCOLHA SEU HEROI", f_titulo, WHITE, MENU_W // 2, 85)
        draw_text(tela, "LEFT / RIGHT para escolher | ENTER ou INICIAR para começar",
                  f_sub, GRAY, MENU_W // 2, 132)

        spacing = 200    # Espaçamento horizontal entre os cards
        start_x = MENU_W // 2 - spacing * 1.5
        styles = {       # Nomes amigáveis dos estilos de tiro
            "potion": "Poção",
            "triple": "Triplo",
            "fireball": "Bola de Fogo",
            "boomerang": "Bumerangue",
        }

        for i, char in enumerate(CHARACTERS):
            x = int(start_x + i * spacing)
            y = MENU_H // 2 + 40
            sel = i == selected  # Este card está selecionado?

            # Desenha o card de fundo
            card = pygame.Rect(x - 70, y - 85, 140, 190)
            pygame.draw.rect(tela, (18, 18, 30), card, border_radius=14)
            pygame.draw.rect(tela, GOLD if sel else (80, 80, 110), card, 2, border_radius=14)  # Borda dourada se selecionado

            draw_character_select_sprite(tela, char, x, y - 10, t)
            draw_text(tela, char["name"], f_sub, WHITE if sel else GRAY, x, y + 72)
            draw_text(tela, styles.get(char["shot_style"], char["shot_style"]),
                      f_pular, (180, 180, 200), x, y + 100)

        pygame.display.flip()

        if start_game:
            if som_clique: som_clique.play()
            return CHARACTERS[selected]  # Retorna o personagem escolhido

