def run_story_generic(slides, title="HISTÓRIA"):
    """
    Exibe uma sequência de slides de história com fade in/out.
    ESPAÇO ou ENTER avança o slide atual.
    Indicadores circulares no rodapé mostram o progresso.
    """
    clock_s=pygame.time.Clock()
    idx=0        # Índice do slide atual
    timer=0.0    # Timer do estado atual
    phase="in"   # Estado: "in" (fadein), "show" (visível), "out" (fadeout)
    alpha=0      # Opacidade atual do texto

    while True:
        dt=clock_s.tick(FPS)/1000.0
        events=pygame.event.get()
        for ev in events:
            if ev.type==pygame.QUIT: pygame.quit(); sys.exit()
            if ev.type==pygame.KEYDOWN and ev.key in(pygame.K_SPACE,pygame.K_RETURN):
                timer=999  # Força avançar o slide atual

        FADE=0.45   # Duração do fade em segundos
        SHOW=3.2    # Duração da exibição do slide em segundos

        timer+=dt
        if phase=="in":
            alpha=min(255,int(255*timer/FADE))   # Aumenta opacidade
            if timer>=FADE: phase="show"; timer=0.0
        elif phase=="show":
            alpha=255
            if timer>=SHOW: phase="out"; timer=0.0
        elif phase=="out":
            alpha=max(0,255-int(255*timer/FADE))  # Diminui opacidade
            if timer>=FADE:
                idx+=1
                if idx>=len(slides): return   # Acabaram os slides
                phase="in"; timer=0.0

        # Fundo gradiente roxo escuro
        draw_gradient_rect(tela,(12,6,24),(32,10,40),(0,0,MENU_W,MENU_H))

        # Círculos decorativos de fundo
        for i in range(6):
            pygame.draw.circle(tela,(40,0,60),(120+i*150,MENU_H//2),80+i*8,3)

        # Título do capítulo
        title_surf=f_titulo.render(title,True,WHITE)
        tela.blit(title_surf,(MENU_W//2-title_surf.get_width()//2,60))

        # Texto do slide com fade
        if idx<len(slides):
            lines=[]
            for part in slides[idx].split("\n"):
                lines.extend(wrap_text(part,f_historia,MENU_W-200))
            total_h=len(lines)*(f_historia.get_height()+8)
            y0=MENU_H//2-total_h//2
            box=pygame.Surface((MENU_W,MENU_H),pygame.SRCALPHA)
            for line in lines:
                txt=f_historia.render(line,True,COR_HISTORIA)
                box.blit(txt,(MENU_W//2-txt.get_width()//2,y0))
                y0+=f_historia.get_height()+8
            box.set_alpha(alpha)     # Aplica o fade
            tela.blit(box,(0,0))

        # Dica de navegação
        hint=f_pular.render("ESPACO ou ENTER para avançar",True,(130,100,60))
        tela.blit(hint,(MENU_W//2-hint.get_width()//2,MENU_H-28))

        # Indicadores de progresso (bolinhas)
        n=len(slides)
        for i in range(n):
            c=(255,165,0) if i==idx else (60,45,20)
            pygame.draw.circle(tela,c,(MENU_W//2-(n-1)*14+i*28,MENU_H-50),6)

        pygame.display.flip()

