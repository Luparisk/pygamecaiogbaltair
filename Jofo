#                                          UTILITÁRIOS DE TELA (SCREEN SHAKE)


SHAKE_FRAMES = 0   # Frames restantes de tremida de tela
SHAKE_POWER  = 0   # Intensidade do tremor

def add_screen_shake(frames=8, power=5):
    """Ativa o efeito de tremida de tela por 'frames' frames com intensidade 'power'."""
    global SHAKE_FRAMES, SHAKE_POWER
    SHAKE_FRAMES = max(SHAKE_FRAMES, frames)
    SHAKE_POWER  = max(SHAKE_POWER, power)

def get_screen_shake_offset():
    """
    Retorna o offset aleatório (dx, dy) para deslocar a tela.
    Decrementa o contador a cada chamada.
    """
    global SHAKE_FRAMES, SHAKE_POWER
    if SHAKE_FRAMES <= 0: return 0,0
    SHAKE_FRAMES -= 1
    return random.randint(-SHAKE_POWER,SHAKE_POWER), random.randint(-SHAKE_POWER,SHAKE_POWER)

#                                          FUNÇÕES MATEMÁTICAS UTILITÁRIAS

def clamp(v,lo,hi): return max(lo,min(hi,v))     # Limita v entre lo e hi
def lerp(a,b,t):    return a+(b-a)*t              # Interpolação linear entre a e b
def normalize(dx,dy):
    """Normaliza um vetor (dx, dy) para comprimento 1. Retorna (0,0) se comprimento 0."""
    d=math.hypot(dx,dy)
    return (0.0,0.0) if d==0 else (dx/d,dy/d)

