class SpiderWebProjectile:
    """
    Projétil de teia da aranha. Voa em direção ao jogador.
    Possui efeito de rotação visual (spin).
    """
    def __init__(self,x,y,vx,vy,damage=12, sprite=None):
        self.x=float(x); self.y=float(y)
        self.vx=vx; self.vy=vy; self.damage=damage
        self.life=220; self.rect=pygame.Rect(int(x)-12,int(y)-12,24,24)
        self.spin=random.uniform(0,math.pi*2)  # Ângulo inicial aleatório
        self.sprite = sprite

    def update(self):
        self.x+=self.vx; self.y+=self.vy
        self.spin+=0.2   # Rotaciona a cada frame
        self.life-=1
        self.rect.center=(int(self.x),int(self.y))

    def draw(self,surf):
        if self.sprite:
            center_blit(surf, self.sprite, self.rect.center)
            return
        # Fallback: círculo branco com linhas radiais (aspecto de teia)
        pygame.draw.circle(surf,(235,235,245),self.rect.center,11)
        pygame.draw.circle(surf,(190,190,205),self.rect.center,11,2)
        for ang in range(0,360,45):
            rad=math.radians(ang)+self.spin
            x2=self.rect.centerx+int(math.cos(rad)*12)
            y2=self.rect.centery+int(math.sin(rad)*12)
            pygame.draw.line(surf,(235,235,245),self.rect.center,(x2,y2),1)


class SpiderBoss:
    """
    Boss 0: Aranha Sombria.
    Move-se em padrão senoidal pela tela e atira teias no jogador.
    Em fúria (<45% HP): velocidade e cadência de ataque aumentam.
    """
    def __init__(self, visuals):
        self.v = visuals
        self.max_hp=650; self.hp=self.max_hp; self.rage=False; self.dead=False
        self.t=0.0; self.attack_cd=0.0
        self.x=BOSS_W*0.62; self.y=140    # Posição inicial
        self.webs=[]; self.flash=0.0
        self.movement_phase=0.0            # Fase do movimento senoidal
        self.rect=pygame.Rect(int(self.x)-120,int(self.y)-80,240,180)

    def take_damage(self,dmg):
        self.hp-=dmg; self.flash=0.14
        self.rage=self.hp<=self.max_hp*0.45   # Entra em fúria abaixo de 45% de vida
        if self.hp<=0: self.dead=True
        return self.dead

    def _spawn_web(self,player,offset_x=0,offset_y=0):
        """Cria uma teia apontada para a posição atual do jogador."""
        sx=self.x+5+offset_x; sy=self.y+40+offset_y
        dx=player.rect.centerx-sx; dy=player.rect.centery-sy
        dist=math.hypot(dx,dy) or 1
        spd=6.6 if self.rage else 5.3   # Mais rápido em fúria
        self.webs.append(SpiderWebProjectile(sx,sy,dx/dist*spd,dy/dist*spd,
                                              damage=15 if self.rage else 12,
                                              sprite=self.v.get("web")))

    def update(self,dt,player):
        self.t+=dt; self.flash=max(0.0,self.flash-dt)

        # Movimento senoidal em X e Y
        self.movement_phase+=dt*(1.75 if self.rage else 1.2)
        self.x=BOSS_W*0.52+math.sin(self.movement_phase*1.6)*420
        self.y=120+math.sin(self.movement_phase*2.2)*110
        if self.rage:
            # Adiciona tremor extra em fúria
            self.x+=math.sin(self.movement_phase*4.5)*50
            self.y+=math.cos(self.movement_phase*3.8)*28
        self.x=clamp(self.x,120,BOSS_W-180); self.y=clamp(self.y,60,300)
        self.rect.update(int(self.x)-120,int(self.y)-80,240,180)

        # Sistema de ataque: cooldown aleatório
        self.attack_cd-=dt
        if self.attack_cd<=0:
            self.attack_cd=random.uniform(0.55,1.0) if self.rage else random.uniform(0.95,1.7)
            self._spawn_web(player)
            if self.rage:
                # Em fúria: dispara 3 teias por vez
                self._spawn_web(player,offset_x=-25,offset_y=10)
                self._spawn_web(player,offset_x=25,offset_y=10)

        # Atualiza e remove teias fora da tela
        for w in self.webs[:]:
            w.update()
            if w.life<=0 or w.rect.right<-50 or w.rect.left>BOSS_W+50 or \
               w.rect.bottom<-50 or w.rect.top>BOSS_H+50:
                self.webs.remove(w)

    def draw_bg(self,surf):
        """Desenha o fundo da fase da aranha."""
        bg = self.v.get("bg")
        if bg: surf.blit(bg, (0, 0)); return
        # Fallback: céu escuro com estrelas e pedras
        surf.fill((19,16,31))
        for i in range(80):
            x=(i*167)%BOSS_W; y=(i*41)%(BOSS_H//2); c=50+(i%4)*20
            pygame.draw.circle(surf,(c,c,c),(x,y),1)
        pygame.draw.rect(surf,(39,33,45),(0,520,BOSS_W,200))
        pygame.draw.ellipse(surf,(92,79,72),(250,520,780,220))
        pygame.draw.polygon(surf,(39,33,45),[(0,0),(170,140),(0,300)])
        pygame.draw.polygon(surf,(39,33,45),[(BOSS_W,0),(BOSS_W-170,140),(BOSS_W,300)])

    def draw(self,surf):
        """Desenha fundo, sprite da aranha, teias e barra de HP."""
        img = self.v.get("bg")
        if img: surf.blit(img, (0, 0))
        else:
            surf.fill((19,16,31))
            for i in range(80):
                x=(i*167)%BOSS_W; y=(i*41)%(BOSS_H//2); c=50+(i%4)*20
                pygame.draw.circle(surf,(c,c,c),(x,y),1)
            pygame.draw.rect(surf,(39,33,45),(0,520,BOSS_W,200))

        img = self.v.get("boss")
        if img:
            center_blit(surf, img.get(self.t), (int(self.x), int(self.y + 20)))
        else:
            # Fallback geométrico: corpo + patas
            cx, cy = int(self.x), int(self.y)
            body_col = (65,25,25) if self.rage else (40,40,40)
            pygame.draw.circle(surf, body_col, (cx, cy+35), 58)
