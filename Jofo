#                                       ANIMAÇÃO DE SPRITES

@dataclass
class SpriteAnim:
    """
    Controla uma animação baseada em lista de frames (imagens).
    fps: quantos frames de animação por segundo.
    loop: se True, repete a animação; se False, para no último frame.
    """
    frames: list    # Lista de surfaces pygame (cada uma é um frame da animação)
    fps: int = 10   # Velocidade da animação
    loop: bool = True  # Repetir ou não

    def get(self, tick):
        """Retorna o frame correto para o tempo 'tick' informado."""
        if not self.frames:
            return None  # Sem frames, retorna nada
        if self.loop:
            # Cicla entre os frames infinitamente
            idx = int(tick * self.fps) % len(self.frames)
        else:
            # Para no último frame quando não faz loop
            idx = min(len(self.frames) - 1, int(tick * self.fps))
        return self.frames[idx]


#                                       FUNÇÕES DE CARREGAMENTO DE IMAGENS


def load_image(path, size=None):
    """
    Carrega uma imagem de 'path'. Se 'size' for fornecido, redimensiona.
    Retorna None se o arquivo não existir ou der erro.
    """
    if not path or not Path(path).exists():
        return None
    try:
        img = pygame.image.load(str(path)).convert_alpha()  # Carrega com canal alpha (transparência)
        if size:
            img = pygame.transform.smoothscale(img, size)   # Redimensiona suavemente
        return img
    except:
        return None


def load_folder_frames(folder: Path, size=None):
    """
    Carrega todos os frames de animação de uma pasta.
    Ordena os arquivos alfabeticamente e retorna uma lista de surfaces.
    Aceita .png, .jpg e .jpeg.
    """
    frames = []
    if not folder.exists():
        return frames  # Retorna lista vazia se pasta não existe
    # Filtra apenas arquivos de imagem e ordena pelo nome
    files = sorted([p for p in folder.iterdir() if p.suffix.lower() in (".png", ".jpg", ".jpeg")])
    for p in files:
        try:
            img = pygame.image.load(str(p)).convert_alpha()
            if size:
                img = pygame.transform.smoothscale(img, size)
            frames.append(img)
        except:
            pass  # Ignora arquivos corrompidos
    return frames


# Controle de direção do sprite 
# Se False: o sprite original olha para a ESQUERDA (o padrão do projeto)
SPRITE_FACES_RIGHT = False

def flip_if_needed(img, facing):
    """
    Espelha horizontalmente a imagem dependendo da direção do personagem.
    'facing' > 0 = indo para a direita.
    Garante que o sprite sempre olhe na direção do movimento.
    """
    if img is None:
        return None
    should_flip = (facing > 0) if not SPRITE_FACES_RIGHT else (facing < 0)
    return pygame.transform.flip(img, True, False) if should_flip else img


def center_blit(surf, img, center):
    """
    Desenha 'img' em 'surf' centralizado no ponto 'center'.
    Atalho comum para evitar cálculos manuais de posição.
    """
    if img is None:
        return
    rect = img.get_rect(center=center)
    surf.blit(img, rect)



