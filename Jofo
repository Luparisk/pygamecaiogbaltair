def run_game():
    """
    Função principal que orquestra todo o fluxo do jogo:
    Menu → Seleção → História → Boss 0 → História → Boss 1 →
    História → Boss 2 → História → Boss 3 → Vitória Final.
    Cada boss pode resultar em game over (com opção de reiniciar).
    """
    global tela
    tela = pygame.display.set_mode((MENU_W, MENU_H))
    pygame.display.set_caption(TITULO_JANELA)

    # Menu principal
    stop_music(200); play_music(MUSICA_MENU)
    menu_t = 0.0
    while True:
        dt = relogio.tick(FPS) / 1000.0; menu_t += dt
        events = pygame.event.get(); clicked_start = False
        for ev in events:
            if ev.type == pygame.QUIT: pygame.quit(); sys.exit()
            if ev.type == pygame.KEYDOWN and ev.key == pygame.K_ESCAPE: pygame.quit(); sys.exit()
            if botao.clicado(ev): clicked_start = True
        render_menu(pygame.mouse.get_pos(), menu_t)
        pygame.display.flip()
        if clicked_start:
            if som_clique: som_clique.play()
            break

    # Seleção de personagem 
    character = character_select()

    # História inicial 
    stop_music(200); play_music(MUSICA_HISTORIA1)
    run_story_generic(HISTORIA, "HALLOWEEN ADVENTURES")

    # Boss 0: Aranha 
    stop_music(200); play_music(MUSICA_BOSS)
    win, player = run_boss_spider(character)
    tela = pygame.display.set_mode((MENU_W, MENU_H))
    if not win:
        stop_music(200)
        if final_screen("GAME OVER", "A aranha venceu"): return run_game()  # Reinicia o jogo
        return

    # História pós-aranha 
    stop_music(200); play_music(MUSICA_FASE2)
    run_story_generic(STORY_AFTER_SPIDER, "APOS A ARANHA")

    # Boss 1: Palhaço 
    stop_music(200); play_music(MUSICA_BOSS)
    win, player = run_boss_clown(character, carried_player=player)
    tela = pygame.display.set_mode((MENU_W, MENU_H))
    if not win:
        stop_music(200)
        if final_screen("GAME OVER", "O palhaço venceu"): return run_game()
        return

    # História pós-palhaço 
    stop_music(200); play_music(MUSICA_FASE2)
    run_story_generic(STORY_AFTER_CLOWN, "APOS O PALHACO")

    # Boss 2: Frankenstein 
    stop_music(200); play_music(MUSICA_BOSS)
    win, player = run_boss_frank(character, carried_player=player)
    tela = pygame.display.set_mode((MENU_W, MENU_H))
    if not win:
        stop_music(200)
        if final_screen("GAME OVER", "Frankenstein venceu"): return run_game()
        return

    # História pós-Frankenstein 
    stop_music(200); play_music(MUSICA_FASE2)
    run_story_generic(STORY_AFTER_FRANK, "APOS FRANKENSTEIN")

    # Boss 3: Lord of Nightmares 
    stop_music(200); play_music(MUSICA_BOSS)
    win, player = run_boss3_final(character, carried_player=player)
    tela = pygame.display.set_mode((MENU_W, MENU_H))
    if not win:
        stop_music(200)
        if final_screen("GAME OVER", "O Lord of Nightmares venceu"): return run_game()
        return

    # História da vitória 
    stop_music(200); play_music(MUSICA_FASE2)
    run_story_generic(STORY_AFTER_LORD, "VITORIA FINAL")

    # Tela de vitória 
    stop_music(200)
    if final_screen("VOCE VENCEU!", "Os quatro bosses foram derrotados"):
        return run_game()  # Permite jogar novamente

