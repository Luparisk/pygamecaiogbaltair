#                                                     FUNÇÕES DE SOM


def load_sound(nome):
    """Carrega um efeito sonoro da pasta base. Retorna None se não encontrar."""
    if not nome or not SOM_ATIVO:
        return None
    p = BASE_DIR / nome
    if not p.exists():
        return None
    try:
        return pygame.mixer.Sound(str(p))
    except:
        return None


def play_music(nome):
    """Carrega e toca uma música em loop infinito."""
    if not nome or not SOM_ATIVO:
        return
    p = BASE_DIR / nome
    if not p.exists():
        return
    try:
        pygame.mixer.music.load(str(p))
        pygame.mixer.music.play(-1)  # -1 = loop infinito
    except:
        pass

def stop_music(fade_ms=300):
    """Para a música atual com fade out de 'fade_ms' milissegundos."""
    if not SOM_ATIVO:
        return
    try:
        pygame.mixer.music.fadeout(fade_ms)
    except:
        pass

